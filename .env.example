# Assest — example .env for local development
# Copy to .env and edit as needed: cp .env.example .env

# App
app_env=development
app_secret_key=change-me-to-a-random-64-char-string
app_host=127.0.0.1
app_port=8000
cors_origins=http://localhost:3000,http://localhost:8000

# Database (dev uses SQLite)
database_url=sqlite+aiosqlite:///./data/assest_dev.db

# Qdrant (set qdrant_mode=memory for ephemeral runs)
qdrant_mode=memory
qdrant_host=localhost
qdrant_port=6333
qdrant_collection_name=assest_knowledge_dev
qdrant_path=./data/qdrant

# Embeddings
embedding_provider=local
embedding_model=all-MiniLM-L6-v2

# Optional external APIs (leave blank for dev/mocks)
openai_api_key=
groq_api_key=your_groq_api_key_here

# Notion / Google / Slack (optional for connectors)
notion_token=your_notion_integration_token_here
google_client_id=
google_client_secret=
slack_bot_token=xoxb-your-slack-bot-token
slack_app_token=xapp-your-slack-app-token

# Redis (optional)
redis_url=redis://localhost:6379/0

# AWS / S3 (optional)
aws_access_key_id=
aws_secret_access_key=
aws_region=ap-south-1
aws_s3_bucket=assest-raw-documents
