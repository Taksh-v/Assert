# Assest — example .env for local development
# Copy to .env and edit as needed: cp .env.example .env

# App
APP_ENV=development
APP_SECRET_KEY=change-me-to-a-random-64-char-string
APP_HOST=0.0.0.0
APP_PORT=8000
SQL_ECHO=false
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Database
DATABASE_URL=sqlite+aiosqlite:///./data/assest_dev.db

# Qdrant (set qdrant_mode=memory for ephemeral runs)
QDRANT_MODE=local
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION_NAME=assest_knowledge_dev
QDRANT_PATH=./data/qdrant

# Embeddings
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=all-MiniLM-L6-v2

# LLM Providers
OPENAI_API_KEY=
GROQ_API_KEY=
GROQ_MODEL=groq/llama-3.3-70b-versatile

OPENROUTER_API_KEY=
OPENROUTER_API_BASE=https://openrouter.ai/api/v1
OPENROUTER_FAST_MODEL=openrouter/google/gemini-2.0-flash-lite:free
OPENROUTER_SMART_MODEL=openrouter/meta-llama/llama-3.1-8b-instruct:free
OPENROUTER_FALLBACK_MODELS=openrouter/z-ai/glm-4.5-air:free

# LiteLLM proxy (optional)
LITELLM_PROXY_URL=http://localhost:4000

# Notion / Google / Slack
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_SIGNING_SECRET=
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
ENABLE_SLACK_BOT=false

# Redis
REDIS_URL=redis://localhost:6379/0

# AWS / S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
AWS_S3_BUCKET=assest-raw-documents

# Observability
LANGFUSE_PUBLIC_KEY=pk-lf-public
LANGFUSE_SECRET_KEY=sk-lf-secret
LANGFUSE_HOST=http://localhost:3000

# Startup Validation Flags
STRICT_MODEL_VALIDATION=false
PERFORM_LLM_PING=false
ACTIVE_PING_ON_STARTUP=false

# Metrics
ENABLE_PROMETHEUS=false
PROMETHEUS_PORT=8001

# Auto Ingest Scheduler
ENABLE_AUTO_INGEST=true
AUTO_INGEST_INTERVAL_MINUTES=60
