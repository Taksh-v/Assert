# Assest — example .env for local development
# Copy to .env and edit as needed: cp .env.example .env

# App
app_env=development
app_secret_key=change-me-to-a-random-64-char-string
app_host=127.0.0.1
app_port=8000
SQL_ECHO=false
cors_origins=http://localhost:3000,http://localhost:8000,http://127.0.0.1:3000,http://127.0.0.1:8000

# Database (dev uses SQLite)
database_url=sqlite+aiosqlite:///./data/assest_dev.db

# Qdrant (set qdrant_mode=memory for ephemeral runs)
qdrant_mode=memory
qdrant_host=localhost
qdrant_port=6333
qdrant_collection_name=assest_knowledge_dev
qdrant_path=./data/qdrant

# Embeddings
embedding_provider=local
embedding_model=all-MiniLM-L6-v2

# Optional external APIs (leave blank for dev/mocks)
openai_api_key=
groq_api_key=your_groq_api_key_here
openrouter_api_key=
openrouter_api_base=https://openrouter.ai/api/v1
openrouter_site_url=http://localhost:3000
openrouter_app_name=Assest Brain
openrouter_fast_model=openrouter/google/gemini-2.0-flash-exp:free
openrouter_smart_model=openrouter/meta-llama/llama-3.1-8b-instruct:free

# Notion / Google / Slack (optional for connectors)
notion_token=your_notion_integration_token_here
slack_client_id=
slack_client_secret=
slack_signing_secret=
google_client_id=
google_client_secret=
slack_bot_token=xoxb-your-slack-bot-token
slack_app_token=xapp-your-slack-app-token
ENABLE_SLACK_BOT=false

# Redis (optional)
redis_url=redis://localhost:6379/0

# AWS / S3 (optional)
aws_access_key_id=
aws_secret_access_key=
aws_region=ap-south-1
aws_s3_bucket=assest-raw-documents

# Auto Ingest Scheduler
# Set to true to enable automatic ingestion of active connectors on an interval
enable_auto_ingest=true
# Interval in minutes between auto ingest runs
auto_ingest_interval_minutes=60

# Langfuse Observability
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com

# Pilot connectors: comma-separated connector ids or connector types (e.g. "slack,notion")
PILOT_CONNECTORS=slack,notion

# Optional: enable prometheus for metrics during pilot
ENABLE_PROMETHEUS=false
