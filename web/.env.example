# Assest frontend environment
# Copy to `.env.local` for local development or set these in your hosting platform.

# Server-only backend origin used by the Next.js route-handler proxy.
# Production must set this to the internal or public FastAPI origin.
ASSEST_API_URL=http://localhost:8000

# Optional server-only API key injected by the frontend proxy when the backend
# is configured to require service-to-service authentication.
ASSEST_BACKEND_API_KEY=

# Browser-facing API adapter path. Keep this relative in production so the
# browser talks to Next.js and Next.js talks to FastAPI.
NEXT_PUBLIC_API_BASE_PATH=/api/backend

# Legacy fallback only. Prefer ASSEST_API_URL so backend origins are not baked
# into browser bundles.
NEXT_PUBLIC_API_URL=

